{
  "name": "onchak-extension",
  "private": true,
  "version": "0.1.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:local": "VITE_API_BASE_URL=http://localhost:8080 npm run build",
    "build:prod": "VITE_API_BASE_URL=https://zephlyglobal.com npm run build",
    "playwright:abrs:profile": "node scripts/open-abrs-coupang-profile.mjs",
    "test": "node --test tests/*.test.ts",
    "test:e2e:abrs": "playwright test --config playwright.abrs.config.mjs",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@mantine/core": "^9.0.0",
    "@mantine/form": "^9.0.2",
    "@mantine/hooks": "^9.0.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.87.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.0",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.1.4",
    "@types/node": "^24.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.4"
  },
  "overrides": {
    "@crxjs/vite-plugin": {
      "rollup": "2.80.0"
    }
  }
}
